{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DesignTokens",
  "description": "All design tokens extracted from the target application, organized by category.",
  "type": "object",
  "required": ["app_url", "extraction_date", "source", "colors", "spacing", "typography", "border_radius"],
  "properties": {
    "app_url": {
      "type": "string",
      "format": "uri",
      "description": "Must match audit-results.json."
    },
    "extraction_date": { "type": "string", "format": "date" },
    "source": {
      "type": "string",
      "enum": ["visual-audit", "source-code", "both"]
    },
    "colors": {
      "type": "object",
      "required": ["brand", "status", "surface", "text", "border"],
      "properties": {
        "brand": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "value", "usage"],
            "properties": {
              "name": { "type": "string" },
              "value": { "type": "string" },
              "usage": { "type": "string" },
              "figma_rgb": {
                "type": "object",
                "properties": {
                  "r": { "type": "number", "minimum": 0, "maximum": 1 },
                  "g": { "type": "number", "minimum": 0, "maximum": 1 },
                  "b": { "type": "number", "minimum": 0, "maximum": 1 }
                }
              }
            }
          }
        },
        "status": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "light"],
            "properties": {
              "name": { "type": "string" },
              "light": {
                "type": "object",
                "required": ["bg", "text", "border"],
                "properties": {
                  "bg": { "type": "string" },
                  "text": { "type": "string" },
                  "border": { "type": "string" }
                }
              },
              "dark": {
                "type": "object",
                "properties": {
                  "bg": { "type": "string" },
                  "text": { "type": "string" },
                  "border": { "type": "string" }
                }
              }
            }
          }
        },
        "surface": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "light"],
            "properties": {
              "name": { "type": "string" },
              "light": { "type": "string" },
              "dark": { "type": ["string", "null"] }
            }
          }
        },
        "text": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "light"],
            "properties": {
              "name": { "type": "string" },
              "light": { "type": "string" },
              "dark": { "type": ["string", "null"] }
            }
          }
        },
        "border": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "light"],
            "properties": {
              "name": { "type": "string" },
              "light": { "type": "string" },
              "dark": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "spacing": {
      "type": "object",
      "required": ["scale"],
      "properties": {
        "scale": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "value_px"],
            "properties": {
              "name": { "type": "string" },
              "value_px": { "type": "number" },
              "value_rem": { "type": ["number", "null"] }
            }
          }
        },
        "layout": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "value_px"],
            "properties": {
              "name": { "type": "string" },
              "value_px": { "type": "number" }
            }
          }
        }
      }
    },
    "typography": {
      "type": "object",
      "required": ["families", "styles"],
      "properties": {
        "families": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "family", "usage"],
            "properties": {
              "name": { "type": "string" },
              "family": { "type": "string" },
              "usage": { "type": "string" },
              "figma_family": {
                "type": ["string", "null"],
                "description": "Figma-safe font name. Use 'Courier New' for monospace, 'Inter' for sans-serif."
              }
            }
          }
        },
        "styles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "category", "font_family", "size_px", "weight", "line_height"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Slash-separated Figma name (e.g., 'heading/page')."
              },
              "category": {
                "type": "string",
                "enum": ["heading", "body", "label", "code", "display"]
              },
              "font_family": { "type": "string" },
              "size_px": { "type": "number" },
              "size_rem": { "type": ["number", "null"] },
              "weight": {
                "type": "integer",
                "enum": [100, 200, 300, 400, 500, 600, 700, 800, 900]
              },
              "line_height": { "type": "number" },
              "letter_spacing": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "border_radius": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "value_px"],
        "properties": {
          "name": { "type": "string" },
          "value_px": { "type": "number" }
        }
      }
    },
    "elevation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "light"],
        "properties": {
          "name": { "type": "string" },
          "light": {
            "type": "object",
            "required": ["css"],
            "properties": {
              "css": { "type": "string" },
              "figma_effects": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["type", "color", "offset", "radius"],
                  "properties": {
                    "type": { "type": "string", "enum": ["DROP_SHADOW", "INNER_SHADOW"] },
                    "color": {
                      "type": "object",
                      "required": ["r", "g", "b", "a"],
                      "properties": {
                        "r": { "type": "number" }, "g": { "type": "number" },
                        "b": { "type": "number" }, "a": { "type": "number" }
                      }
                    },
                    "offset": {
                      "type": "object",
                      "required": ["x", "y"],
                      "properties": { "x": { "type": "number" }, "y": { "type": "number" } }
                    },
                    "radius": { "type": "number" },
                    "spread": { "type": "number", "default": 0 }
                  }
                }
              }
            }
          },
          "dark": {
            "type": "object",
            "properties": {
              "css": { "type": "string" },
              "figma_effects": { "type": "array" }
            }
          }
        }
      }
    },
    "icons": {
      "type": "object",
      "properties": {
        "library": { "type": ["string", "null"] },
        "count": { "type": "integer" },
        "default_size_px": { "type": ["number", "null"] },
        "icons": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "usage"],
            "properties": {
              "name": { "type": "string" },
              "usage": { "type": "string" },
              "svg": { "type": ["string", "null"] }
            }
          }
        }
      }
    }
  }
}
