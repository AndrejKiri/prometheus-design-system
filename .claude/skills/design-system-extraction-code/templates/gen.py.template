#!/usr/bin/env python3
"""
gen.py — Design System Docs Site Generator
===========================================
Generated by design-system-extraction-code skill.
Run from the project folder:

    python3 gen.py

Re-run any time tokens.json or components.json change. Existing HTML files are
overwritten (stale content is never left behind). Screenshots are COPIED (not
symlinked) so GitHub Pages serves them correctly.

Watch mode (re-generate on JSON change):
    python3 gen.py --watch
"""

import argparse
import json
import os
import re
import shutil
import time
from pathlib import Path

# ── Config ──────────────────────────────────────────────────────────────────

PROJECT_DIR   = Path(__file__).parent
OUTPUT_DIR    = PROJECT_DIR / "design-system"
SCREENSHOTS_SRC  = PROJECT_DIR / "screenshots"
SCREENSHOTS_DEST = OUTPUT_DIR / "screenshots"
TOKENS_PATH      = PROJECT_DIR / "tokens.json"
COMPONENTS_PATH  = PROJECT_DIR / "components.json"
AUDIT_PATH       = PROJECT_DIR / "audit-results.json"

# Read from CLAUDE.md if present; otherwise leave empty
GITHUB_REPO_URL = ""   # set to e.g. "https://github.com/user/repo"
APP_NAME        = "Design System"

# ── Helpers ──────────────────────────────────────────────────────────────────

def load(path):
    with open(path) as f:
        return json.load(f)

def write(path, content):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")
    print(f"  wrote {path.relative_to(PROJECT_DIR)}")

def copy_screenshots():
    """Copy screenshots/ into design-system/screenshots/ (not a symlink)."""
    if SCREENSHOTS_SRC.exists():
        if SCREENSHOTS_DEST.exists():
            shutil.rmtree(SCREENSHOTS_DEST)
        shutil.copytree(SCREENSHOTS_SRC, SCREENSHOTS_DEST)
        print(f"  copied screenshots/ ({sum(1 for _ in SCREENSHOTS_DEST.iterdir())} files)")
    else:
        print("  [warn] screenshots/ not found — skipping copy")

def nav_sidebar(active_page=""):
    """Return the shared sidebar nav HTML. active_page = filename without .html."""
    pages = [
        ("index",          "Home"),
        ("tokens",         "Tokens"),
        ("icons",          "Icons"),
        ("components",     "Components"),
        ("patterns",       "Patterns"),
        ("action-items",   "Action Items"),
        ("audit-report",   "Audit Report"),
        ("inconsistencies","Inconsistencies"),
        ("figma",          "Figma Plugin"),
        ("changelog",      "Changelog"),
    ]
    items = ""
    for slug, label in pages:
        active = ' class="active"' if slug == active_page else ""
        href = f"{slug}.html"
        items += f'      <li{active}><a href="{href}">{label}</a></li>\n'
    return f"""  <nav class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <span class="sidebar-title">{APP_NAME}</span>
      <button class="sidebar-close" id="sidebar-close">&#x2715;</button>
    </div>
    <ul>
{items}    </ul>
  </nav>"""

def page_shell(title, active_page, body, extra_head=""):
    return f"""<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} — {APP_NAME}</title>
  <link rel="stylesheet" href="styles.css">
  {extra_head}
</head>
<body>
  <button class="burger" id="burger">&#9776;</button>
  <div class="overlay" id="overlay"></div>
{nav_sidebar(active_page)}
  <main class="content">
{body}
  </main>
  <script src="main.js"></script>
</body>
</html>"""

# ── Pages ────────────────────────────────────────────────────────────────────

def gen_index(tokens, components, audit):
    """Homepage — 5 category-tagged cards, not emoji cards."""
    categories = [
        ("tokens",       "Tokens",       "Color, spacing, typography, border-radius."),
        ("components",   "Components",   f"{len(components.get('components', []))} extracted components with variants and specs."),
        ("action-items", "Action Items", f"{len(components.get('action_items', []))} PR-style tasks with priority and effort."),
        ("audit-report", "Audit Report", f"{len(audit.get('pages_audited', []))} pages audited, {len(audit.get('inconsistencies', []))} inconsistencies."),
        ("figma",        "Figma Plugin", "Bootstrap styles in Figma from extracted tokens."),
    ]
    cards = ""
    for slug, label, desc in categories:
        cards += f"""    <a class="card" href="{slug}.html">
      <h2>{label}</h2>
      <p>{desc}</p>
    </a>
"""
    body = f"""    <h1>{APP_NAME}</h1>
    <p class="doc-subtitle">Extracted design system — generated by <code>gen.py</code>.</p>
    <div class="card-grid">
{cards}    </div>"""
    write(OUTPUT_DIR / "index.html", page_shell("Home", "index", body))


def gen_tokens(tokens):
    # {{POPULATE_FROM_TOKENS}} — fill color swatches, spacing scale, typography styles, border radius
    body = "<h1>Tokens</h1>\n    <p class=\"doc-subtitle\">Design tokens extracted from the application.</p>\n"
    body += "    <!-- TODO: generate token tables from tokens.json -->\n"
    write(OUTPUT_DIR / "tokens.html", page_shell("Tokens", "tokens", body))


def gen_components(components, tokens):
    # Components overview page
    comp_list = components.get("components", [])
    # Order: complex → medium → simple (within each category, alphabetical)
    order = {"complex": 0, "medium": 1, "simple": 2}
    sorted_comps = sorted(comp_list, key=lambda c: (order.get(c.get("complexity", "simple"), 2), c.get("name", "")))
    items = ""
    for comp in sorted_comps:
        slug = comp.get("slug", "")
        name = comp.get("name", "")
        desc = comp.get("description", "")
        complexity = comp.get("complexity", "")
        items += f'    <a class="card" href="components/{slug}.html"><span class="tag">{complexity}</span><h3>{name}</h3><p>{desc}</p></a>\n'
    body = f"<h1>Components</h1>\n    <p class=\"doc-subtitle\">{len(comp_list)} components.</p>\n    <div class=\"card-grid\">\n{items}    </div>"
    write(OUTPUT_DIR / "components.html", page_shell("Components", "components", body))

    # Individual component pages
    for comp in comp_list:
        gen_component_page(comp, tokens)


def gen_component_page(comp, tokens):
    slug = comp.get("slug", "unknown")
    name = comp.get("name", slug)
    desc = comp.get("description", "")
    # Section order: title, do/dont, #design, Component Reference, #implementation, #layout, #accessibility
    # mock CSS class: .mock-<slug>
    body = f"""    <h1 id="top">{name}</h1>
    <p class="doc-subtitle">{desc}</p>
    <section id="design">
      <h2>Design</h2>
      <div class="mock-{slug}"><!-- visual example --></div>
    </section>
    <section id="implementation">
      <h2>Implementation</h2>
      <pre><code>{comp.get('code_example', '<!-- no example provided -->')}</code></pre>
    </section>
    <section id="layout">
      <h2>Layout</h2>
      <!-- layout specs table here -->
    </section>
    <section id="accessibility">
      <h2>Accessibility</h2>
      <p>{comp.get('accessibility_notes', '')}</p>
    </section>"""

    # Component reference with screenshots
    refs = comp.get("component_references", [])
    if refs:
        body += "\n    <details class=\"ref\"><summary>Component Reference</summary>\n"
        for ref in refs:
            body += f"      <img src=\"../screenshots/{ref}\" alt=\"{name} screenshot\" loading=\"lazy\">\n"
        body += "    </details>"

    # nav: component pages need ../ prefix
    def comp_nav(active):
        pages = [
            ("index",          "Home"),
            ("tokens",         "Tokens"),
            ("icons",          "Icons"),
            ("components",     "Components"),
            ("patterns",       "Patterns"),
            ("action-items",   "Action Items"),
            ("audit-report",   "Audit Report"),
            ("inconsistencies","Inconsistencies"),
            ("figma",          "Figma Plugin"),
            ("changelog",      "Changelog"),
        ]
        items = ""
        for s, label in pages:
            act = ' class="active"' if s == active else ""
            href = f"../{s}.html"
            items += f'      <li{act}><a href="{href}">{label}</a></li>\n'
        return f"""  <nav class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <span class="sidebar-title">{APP_NAME}</span>
      <button class="sidebar-close" id="sidebar-close">&#x2715;</button>
    </div>
    <ul>
{items}    </ul>
  </nav>"""

    html = f"""<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{name} — {APP_NAME}</title>
  <link rel="stylesheet" href="../styles.css">
</head>
<body>
  <button class="burger" id="burger">&#9776;</button>
  <div class="overlay" id="overlay"></div>
{comp_nav("components")}
  <main class="content">
{body}
  </main>
  <script src="../main.js"></script>
</body>
</html>"""
    write(OUTPUT_DIR / "components" / f"{slug}.html", html)


def gen_action_items(components):
    items = components.get("action_items", [])
    cards = ""
    for ai in items:
        labels = " ".join(f'<span class="tag">{l}</span>' for l in ai.get("labels", []))
        issue_link = ""
        if GITHUB_REPO_URL:
            issue_link = f' <a class="issue-link" href="{GITHUB_REPO_URL}/issues/new?title={ai.get(\"title\",\"\")}" target="_blank">Open issue</a>'
        cards += f"""    <div class="pr-card" data-priority="{ai.get('priority','')}">
      <div class="pr-card-header">
        <span class="pr-number">{ai.get('id','')}</span>
        <span class="pr-title">{ai.get('title','')}</span>
        {labels}
        {issue_link}
      </div>
      <p>{ai.get('description','')}</p>
    </div>
"""
    body = f"<h1>Action Items</h1>\n    <p class=\"doc-subtitle\">{len(items)} tasks.</p>\n{cards}"
    write(OUTPUT_DIR / "action-items.html", page_shell("Action Items", "action-items", body))


def gen_audit_report(audit):
    pages = audit.get("pages_audited", [])
    rows = ""
    for p in pages:
        rows += f"    <tr><td>{p.get('name','')}</td><td><a href=\"{p.get('url','')}\">link</a></td></tr>\n"
    body = f"<h1>Audit Report</h1>\n    <table>\n    <thead><tr><th>Page</th><th>URL</th></tr></thead>\n    <tbody>\n{rows}    </tbody>\n    </table>"
    write(OUTPUT_DIR / "audit-report.html", page_shell("Audit Report", "audit-report", body))


def gen_stubs():
    stubs = {
        "icons":          "Icons",
        "patterns":       "Patterns",
        "inconsistencies":"Inconsistencies",
        "figma":          "Figma Plugin",
        "changelog":      "Changelog",
        "migration":      "Migration Guide",
    }
    for slug, title in stubs.items():
        out = OUTPUT_DIR / f"{slug}.html"
        if not out.exists():
            write(out, page_shell(title, slug, f"<h1>{title}</h1>\n    <p><!-- TODO --></p>"))


# ── Main ─────────────────────────────────────────────────────────────────────

def generate():
    print("Generating design system docs site...")
    tokens     = load(TOKENS_PATH)
    components = load(COMPONENTS_PATH)
    audit      = load(AUDIT_PATH)

    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    copy_screenshots()
    gen_index(tokens, components, audit)
    gen_tokens(tokens)
    gen_components(components, tokens)
    gen_action_items(components)
    gen_audit_report(audit)
    gen_stubs()
    print("Done.")


def main():
    parser = argparse.ArgumentParser(description="Generate design system docs site from JSON files.")
    parser.add_argument("--watch", action="store_true", help="Re-generate when JSON files change.")
    args = parser.parse_args()

    generate()
    if args.watch:
        print("Watching for changes (Ctrl+C to stop)...")
        watched = {p: p.stat().st_mtime for p in [TOKENS_PATH, COMPONENTS_PATH, AUDIT_PATH] if p.exists()}
        while True:
            time.sleep(2)
            for p, mtime in list(watched.items()):
                if p.exists() and p.stat().st_mtime != mtime:
                    print(f"\n{p.name} changed — regenerating...")
                    generate()
                    watched[p] = p.stat().st_mtime


if __name__ == "__main__":
    main()
