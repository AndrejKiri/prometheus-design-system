  "domain_lexicon": [
    {
      "term": "PromQL",
      "definition": "Prometheus Query Language — the expression language entered in the /query editor.",
      "ui_surface": "/query expression input"
    },
    {
      "term": "Scrape pool",
      "definition": "A logical grouping of scrape targets sharing the same job/discovery configuration. Drives the accordion grouping on /targets and /service-discovery.",
      "ui_surface": "/targets, /service-discovery (accordion items)"
    },
    {
      "term": "Target",
      "definition": "A single endpoint Prometheus scrapes for metrics. Each renders one row inside its scrape-pool accordion.",
      "ui_surface": "/targets accordion rows"
    },
    {
      "term": "UP / DOWN",
      "definition": "Boolean health of a target's last scrape. UP renders as the ok status pill, DOWN renders as the error status pill.",
      "ui_surface": "/targets Health Status Badge"
    },
    {
      "term": "Alerting rule",
      "definition": "A rule that emits an alert when its PromQL expression matches. Listed on /alerts.",
      "ui_surface": "/alerts"
    },
    {
      "term": "Recording rule",
      "definition": "A rule that pre-computes a PromQL expression and stores the result as a new series. Listed on /rules.",
      "ui_surface": "/rules"
    },
    {
      "term": "Label",
      "definition": "Key=value pair attached to a metric or target. Should always render in the Label Badge component.",
      "ui_surface": "/targets, /service-discovery, /tsdb-status"
    },
    {
      "term": "Relabeling",
      "definition": "Server-side label rewriting at scrape time. Disclosed via the 'show relabeling' link inside a /service-discovery panel.",
      "ui_surface": "/service-discovery"
    },
    {
      "term": "TSDB",
      "definition": "Time-series database — the storage layer. /tsdb-status surfaces head-block health and Top-N label statistics.",
      "ui_surface": "/tsdb-status"
    },
    {
      "term": "Alertmanager",
      "definition": "External component that receives alerts from Prometheus. Discovery state shown on /alertmanager-discovery.",
      "ui_surface": "/alertmanager-discovery"
    }
  ],
